# Required — Telegram Bot
BOT_TOKEN=your-telegram-bot-token
CHAT_ID=your-chat-id

# Optional — AI (Gemini)
# Leave empty to disable AI features (template fallback active)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional — Claude Chatbot
# Leave empty to disable chatbot mode (slash commands still work)
CLAUDE_ENDPOINT=https://marketriskmonitor.com/api/analyze
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TIMEOUT=120s

# Chat History
CHAT_HISTORY_LIMIT=50
CHAT_HISTORY_TTL=168h

# Storage
DATA_DIR=/app/data

# COT Settings
COT_FETCH_INTERVAL=6h
COT_HISTORY_WEEKS=52

# AI Cache
AI_CACHE_TTL=1h
AI_MAX_RPM=15
AI_MAX_DAILY=200

# Logging
LOG_LEVEL=info

# Health Check
HEALTH_ADDR=:8080

# Optional — EIA (Energy Information Administration)
# Free API key from https://www.eia.gov/opendata/register.php
# Enables energy seasonal context (OIL, RBOB, ULSD inventory/refinery data)
EIA_API_KEY=
