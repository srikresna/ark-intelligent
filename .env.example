# Required — Telegram Bot
BOT_TOKEN=your-telegram-bot-token
CHAT_ID=your-chat-id

# Optional — AI (Gemini)
# Leave empty to disable AI features (template fallback active)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional — Claude Chatbot
# Leave empty to disable chatbot mode (slash commands still work)
CLAUDE_ENDPOINT=https://marketriskmonitor.com/api/analyze
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TIMEOUT=120s

# Chat History
CHAT_HISTORY_LIMIT=50
CHAT_HISTORY_TTL=168h

# Storage
DATA_DIR=/app/data

# COT Settings
COT_FETCH_INTERVAL=6h
COT_HISTORY_WEEKS=52

# Impact Bootstrap
# How many months of historical events to backfill on startup (default: 12)
IMPACT_BOOTSTRAP_MONTHS=12

# AI Cache
AI_CACHE_TTL=1h
AI_MAX_RPM=15
AI_MAX_DAILY=200

# Logging
LOG_LEVEL=info

# Health Check
HEALTH_ADDR=:8080

# Optional — EIA (Energy Information Administration)
# Free API key from https://www.eia.gov/opendata/register.php
# Enables energy seasonal context (OIL, RBOB, ULSD inventory/refinery data)
EIA_API_KEY=

# Price APIs — TwelveData (primary, comma-separated for multi-key round-robin)
TWELVE_DATA_API_KEYS=
# Backward compat: TWELVE_DATA_API_KEY= also works for single key

# Intraday multi-timeframe
INTRADAY_FETCH_INTERVAL=15m
INTRADAY_RETENTION_DAYS=60

# Optional — CoinGecko (demo plan)
# Get free demo API key from https://www.coingecko.com/en/api
# Enables BTC dominance, altcoin market cap (TOTAL3), market sentiment proxy
COINGECKO_API_KEY=

# Optional — Firecrawl (web scraping API)
# API key from https://firecrawl.dev — enables AAII Investor Sentiment Survey
FIRECRAWL_API_KEY=

# Optional — FRED (Federal Reserve Economic Data)
# Free API key from https://fred.stlouisfed.org/docs/api/api_key.html
# Enables macro dashboard: yields, labor, inflation, Fed balance sheet, TGA
FRED_API_KEY=

# Optional — Massive (formerly Polygon.io) — multiple keys for rotation
# Get free API key from https://massive.com
# For multiple keys (free tier rotation): MASSIVE_API_KEYS=key1,key2,key3
MASSIVE_API_KEYS=
# Backward compat: single key also works
# MASSIVE_API_KEY=

# Massive S3 Flat Files access (optional, for historical panel research)
MASSIVE_S3_ACCESS_KEY=
MASSIVE_S3_SECRET_KEY=

# Optional — Bybit API (crypto microstructure confirmation)
# Get API key from https://www.bybit.com/app/user/api-management
# Note: many market data endpoints are public (no key needed for orderbook/trades)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# Feature flags (defaults: auto-detect from API key presence)
ENABLE_BYBIT_MICROSTRUCTURE=
ENABLE_MASSIVE_RESEARCH=
ENABLE_FACTOR_ENGINE=true
ENABLE_STRATEGY_PLAYBOOK=true
ENABLE_PORTFOLIO_HEAT=true
