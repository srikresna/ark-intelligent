# ===========================================================================
# ARK Community Intelligent v1 — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================================================

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Telegram Bot API token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Default Telegram chat ID for alerts and notifications
CHAT_ID=your_chat_id_here

# ---------------------------------------------------------------------------
# AI (Optional — bot works without, uses template fallback)
# ---------------------------------------------------------------------------

# Google Gemini API key (for AI-powered analysis)
GEMINI_API_KEY=

# Gemini model (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ---------------------------------------------------------------------------
# STORAGE
# ---------------------------------------------------------------------------

# BadgerDB data directory (default: /app/data)
# DATA_DIR=/app/data

# ---------------------------------------------------------------------------
# COT DATA
# ---------------------------------------------------------------------------

# How often to fetch COT data from CFTC (default: 6h)
# COT_FETCH_INTERVAL=6h

# Weeks of COT history to maintain (default: 52)
# COT_HISTORY_WEEKS=52

# ---------------------------------------------------------------------------
# QUANTITATIVE
# ---------------------------------------------------------------------------

# Surprise index recalculation interval (default: 1h)
# SURPRISE_CALC_INTERVAL=1h

# Confluence score recalculation interval (default: 2h)
# CONFLUENCE_CALC_INTERVAL=2h

# Surprise decay half-life in days (default: 30)
# SURPRISE_DECAY_HALFLIFE=30

# Surprise lookback window in days (default: 90)
# SURPRISE_WINDOW_DAYS=90

# ---------------------------------------------------------------------------
# AI SETTINGS
# ---------------------------------------------------------------------------

# AI response cache TTL (default: 1h)
# AI_CACHE_TTL=1h

# Max AI requests per minute (default: 15)
# AI_MAX_RPM=15

# ---------------------------------------------------------------------------
# ALERTS
# ---------------------------------------------------------------------------

# Default alert minutes before event, comma-separated (default: 60,15,5,1)
# DEFAULT_ALERT_MINUTES=60,15,5,1

# Default impact levels to alert on (default: High,Medium)
# DEFAULT_ALERT_IMPACTS=High,Medium

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
